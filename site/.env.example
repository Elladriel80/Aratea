# Aratea site — environment variables
# Copy to .env.local for local dev. On Vercel, set these in the project UI.
# NEXT_PUBLIC_* are exposed in the browser bundle — never put secrets there.

# Predictor manifest source (the live dashboard serves it at /predictor_manifest.json).
NEXT_PUBLIC_MANIFEST_URL=https://aratea-app.vercel.app/predictor_manifest.json

# On-chain reads (Arbitrum Sepolia testnet in Phase 1).
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_CHAIN_ID=421614

# Deployed contract addresses. Zero until the testnet deployment is executed —
# the site then shows a "testnet pending" state instead of live token figures.
NEXT_PUBLIC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Block explorer (default: Arbitrum Sepolia Arbiscan).
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.arbiscan.io

# Server-only (NOT exposed to the browser): Discord webhook the contributor
# form posts to. Leave empty to disable real sending (the form then no-ops
# gracefully and the action returns a friendly message).
CONTRIB_DISCORD_WEBHOOK=

# ─────────────────────────────────────────────────────────────────────────
# Contributor account (/contribuer) — link GitHub handle ↔ wallet.
# ALL server-only. NEVER prefix any of these with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────

# GitHub OAuth App (scope read:user only). Used to prove the GitHub handle.
# Callback URL to register in the OAuth App: <origin>/api/contributor/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# HMAC secret signing the session + OAuth-tx cookies. Generate a long random
# value, e.g.  openssl rand -base64 48
SESSION_SECRET=

# GitHub App that opens the registry PR (least privilege: installed on THIS repo
# only, permissions = Contents: write + Pull requests: write). Leave unset for
# local dev: the flow then returns the verified row + an edit link for manual
# ratification instead of opening a PR.
GH_APP_ID=
# PEM private key. On Vercel, paste with literal \n between lines (they are
# restored to real newlines at runtime).
GH_APP_PRIVATE_KEY=
GH_APP_INSTALLATION_ID=

# Target repo for the registry PR (owner/name). Defaults to Elladriel80/Aratea.
GH_REPO=Elladriel80/Aratea
